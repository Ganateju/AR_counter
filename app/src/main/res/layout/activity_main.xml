<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:opencv="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.opencv.android.JavaCameraView
        android:id="@+id/camera_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        opencv:show_fps="true" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:background="#B3000000"
        android:padding="15dp"
        android:text="AI DETECTOR ACTIVE"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/slider_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/btn_action"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="20dp"
        android:background="#B3000000"
        android:orientation="vertical"
        android:padding="15dp">

        <TextView
            android:id="@+id/sensitivity_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Object Spacing (Sensitivity): 150"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/distance_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:max="500"
            android:progress="150" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_action"
        android:layout_width="240dp"
        android:layout_height="75dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="60dp"
        android:backgroundTint="#00FF00"
        android:text="START SCAN"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/result_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2000000"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/final_result_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOTAL COUNT: 0"
            android:textColor="#00FF00"
            android:textSize="36sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:padding="15dp"
            android:text="NEW SCAN"
            android:textSize="16sp" />
    </LinearLayout>

</RelativeLayout>